<%- include("templates/header", {title: title, user: user}) %>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-6 col-lg-5">
                <h2 class="mb-4 text-center">Log in</h2>
                <form action="/backupLoginSubmit" method="post">
                    <div class="mb-3">
                        <label class="form-label">
                            <strong>Email</strong>
                        </label>
                        <input name="email" type="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Find your security question</strong></label>
                        <%- include("templates/security-questions") %>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Provide the answer to your question</strong></label>
                        <input name="answer" type="text" class="form-control" required>
                    </div>
                    <button class="btn btn-primary w-100">
                        Submit
                    </button>
                </form>
                <p class="mt-3 text-center">
                    Remembered your password?
                    <a href="/login">Login normally</a>
                </p>
                <p class="mt-3 text-center">
                    Don't have an account?
                    <a href="/signup">Create one</a>
                </p>
                <div class="alert alert-danger mt-4 shadow-sm" role="alert">
                    <strong>IMPORTANT: If you have forgotten your password, make a new one as soon as possible!</strong>
                </div>
            </div>
        </div>
    </div>
<%- include("templates/footer") %>