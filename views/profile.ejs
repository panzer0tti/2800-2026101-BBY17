<%- include("templates/header") %>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-6 col-lg-5">
                <h2 class="mb-4 text-center">User Profile</h2>
                <form action="/updateProfile" method="post">
                    <fieldset id="personalInfoFields" disabled>
                        <div class="mb-3">
                            <label class="form-label">
                                <strong>Name</strong>
                            </label>
                            <input type="text" id="nameInput" class="form-control"
                                name="name" placeholder="Enter your name" value="<%= name %>" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">
                                <strong>Location</strong>
                            </label>
                            <input type="text" id="locationInput" class="form-control"
                                name="location" placeholder="Eg. Vancouver" value="<%= location %>" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">
                                <strong>Phone Number</strong>
                            </label>
                            <input type="text" id="phoneInput" class="form-control" pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}" 
                                name="phoneNum" placeholder="Eg. 123-456-7890" value="<%= phoneNum %>" />
                        </div>
                    </fieldset>
                    <div class="d-flex gap-2 mt-4">
                        <button id="editButton" type="button" class="btn btn-secondary w-50">
                            Edit
                        </button>
                        <button id="saveButton" type="submit" class="btn btn-primary w-50">
                            Save
                        </button>
                    </div>
                    <div class="d-flex justify-content-center mt-3">
                        <a href="/changePassword" id="changePasswordButton" class="btn btn-danger w-100">
                            Change Password
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
<%- include("templates/footer") %>