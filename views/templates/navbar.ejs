<nav class="navbar navbar-expand-lg custom-header-bar fw-bold">
    <div class="container-fluid">
        <a class="navbar-brand title" href="/">BeWilder</a>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto py-2">
                <% const links=user ? locals.navLinksAuth : locals.navLinksUnauth %>
                <% for (let link of links) { %>
                    <li class="nav-item">
                    <% if (link.name==="Logout" ) { %>
                        <a class="nav-link app-links btn btn-danger rounded-pill px-3" href="<%= link.url %>">
                            <%= link.name %>
                        </a>
                        <% } else { %>
                            <a href="<%= link.url %>"
                                class="nav-link app-links <%= link.url === locals.folder ? 'active' : '' %>">
                                <%= link.name %>
                            </a>
                        <% } %>
                    </li>
                <% } %>
            </ul>
            <form class="d-flex search-bar" role="search" action="/search" method="post">
                <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
                <button class="btn btn-outline-success" type="submit">Search</button>
            </form>
        </div>
        <button class="navbar-toggler custom-toggler ms-3" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarNav">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</nav>